# ── Database ──────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=retrix

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=          # leave empty if no auth

# ── AI API Keys ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
MINIMAX_API_KEY=          # optional

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DOMAIN=localhost
ENV=development
SECRET_KEY=change-this-to-a-random-32-char-string

# ── Admin Account ─────────────────────────────────────────
# Run: python -c "from app.core.auth import hash_password; print(hash_password('yourpassword'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=      # bcrypt hash of admin password

# ── GitHub ────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...      # personal access token with repo scope
GITHUB_ORG=               # optional: org name for repo creation

# ── Workspace ─────────────────────────────────────────────
WORKSPACE_ROOT=D:\Projects   # local folder where workers operate

# ── Budget ────────────────────────────────────────────────
DAILY_BUDGET_LIMIT=5.0       # USD per day (0 = no limit)
PROJECT_BUDGET_LIMIT=2.0     # USD per project (0 = no limit)

# ── Notifications ─────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...   # optional
